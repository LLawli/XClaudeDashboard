#!/usr/bin/env bash
# Pre-commit hook: block commits whose STAGED content doesn't match the
# project's rustfmt style. Mirrors the CI `fmt` check (cargo fmt --all --
# --check under stable rustfmt, pinned by rust-toolchain.toml) so formatting
# drift never reaches CI again.
#
# The staged tree is checked out into a temp dir and checked there: the
# working tree can't mask an unformatted staged hunk (fmt run but not
# re-staged) and unrelated dirty files can't block a clean commit.
#
# Enable once per clone:  git config core.hooksPath .githooks
set -euo pipefail

if ! command -v cargo >/dev/null 2>&1; then
    echo "pre-commit: cargo not found, skipping fmt check" >&2
    exit 0
fi

tmpdir="$(mktemp -d)"
trap 'rm -rf "$tmpdir"' EXIT
git checkout-index --prefix="$tmpdir/" -a

if ! (cd "$tmpdir" && cargo fmt --all -- --check); then
    echo >&2
    echo "pre-commit: staged formatting check failed. Run 'cargo fmt --all' and re-stage." >&2
    exit 1
fi
