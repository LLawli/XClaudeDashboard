# nfpm config for the .deb / .rpm packages (https://nfpm.goreleaser.com).
# The release workflow sets NFPM_ARCH / NFPM_VERSION / NFPM_BIN per architecture
# and feeds the SAME prebuilt binary the tarballs use ("compile once, repackage
# many").
name: xclaude
arch: ${NFPM_ARCH}
platform: linux
version: ${NFPM_VERSION}
maintainer: "Luka Kuuhaku <contato@lukakuuhaku.dev>"
description: |
  Real-time TUI dashboard for XClaudeUsage: live 5h/7d window usage,
  burn rate, per-model/per-device breakdown and cost for Claude Code.
  Requires XClaudeUsage (https://github.com/SrDarf/XClaudeUsage).
homepage: "https://github.com/LLawli/XClaudeDashboard"
license: "MIT"
section: utils
contents:
  - src: ${NFPM_BIN}
    dst: /usr/bin/xclaude
